# Backend
PORT=3001
# Sim clock speed multiplier (1 = real time). Higher = faster demo.
SIM_SPEED=1

# Dashboard reads this to reach the backend
VITE_BACKEND_URL=http://localhost:3001

# Discord bot (optional — bot skips gracefully if unset)
DISCORD_TOKEN=
DISCORD_ALERT_CHANNEL_ID=
BACKEND_URL=http://localhost:3001

# LLM humanizer (optional — bot falls back to templates if unset)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
BOT_LLM=on
PROACTIVE=on
