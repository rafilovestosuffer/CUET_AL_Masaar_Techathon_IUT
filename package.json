{
  "name": "officepulse",
  "version": "0.1.0",
  "private": true,
  "description": "Real-time office device monitoring: one backend, a live dashboard, and a Discord bot.",
  "workspaces": [
    "backend",
    "dashboard",
    "bot"
  ],
  "scripts": {
    "dev:all": "concurrently -n backend,dashboard,bot -c blue,green,magenta \"npm -w backend run dev\" \"npm -w dashboard run dev\" \"npm -w bot run dev\"",
    "dev:backend": "npm -w backend run dev",
    "dev:dashboard": "npm -w dashboard run dev",
    "dev:bot": "npm -w bot run dev",
    "test": "node --test backend/test/*.test.js",
    "demo:alert": "node -e \"fetch('http://localhost:3001/api/sim/scenario/forgot-devices',{method:'POST'}).then(r=>r.json()).then(j=>console.log('scenario:',j)).catch(e=>console.error(e.message))\"",
    "demo:warmup": "node -e \"fetch('http://localhost:3001/api/sim/scenario/business-hours',{method:'POST'}).then(r=>r.json()).then(j=>console.log('scenario:',j)).catch(e=>console.error(e.message))\""
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  }
}
